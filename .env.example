# This project not use single .env file.
# Ensure to use multiple env file like .env.Development, .env.Production, etc.

# app
ASPNETCORE_ENVIRONMENT=Development
DOMAIN=http://localhost:8080

# database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=TodoDb_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_CONNECTION_STRING=Host=${DB_HOST};Port=${DB_PORT};Database=${DB_NAME};Username=${DB_USER};Password=${DB_PASSWORD}

# postgres image
POSTGRES_PASSWORD=${DB_PASSWORD}
POSTGRES_USER=${DB_USER}
POSTGRES_DB=${DB_NAME}

# jwt
JWT_SECRET=supersecretkeythatisatleast32characterslong
JWT_ISSUER=todolist-api
JWT_AUDIENCE=todolist-client
JWT_EXPIRY_MINUTES=5
JWT_REFRESH_EXPIRY_DAYS=3

# rabbitmq
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# rabbitmq image
RABBITMQ_DEFAULT_USER=${RABBITMQ_USER}
RABBITMQ_DEFAULT_PASS=${RABBITMQ_PASSWORD}

# smtp / email
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=kenna.rosenbaum@ethereal.email
SMTP_PASSWORD=CnnA4Ph843prgK41JR
SMTP_FROM_EMAIL=noreply@todolist.com
SMTP_FROM_NAME="TodoList App"

# redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CONNECTION_STRING=${REDIS_HOST}:${REDIS_PORT}